modules = ["nodejs-20", "bash", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["github:1.0.0", "python_openai_ai_integrations:1.0.0"]

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
DB_NAME = "clinica"

[userenv.development]
EXPO_PUBLIC_BACKEND_URL = "https://1a88ce60-54d7-432b-a038-dd5cf757c637-00-35in8reqfcisl.spock.replit.dev:8000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "MongoDB"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && REACT_NATIVE_PACKAGER_HOSTNAME=$(printenv REPLIT_DEV_DOMAIN) CI=1 npx expo start --port 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && uvicorn server:app --host 0.0.0.0 --port 8000"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "MongoDB"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "mkdir -p .local/mongodb-data && mongod --dbpath .local/mongodb-data --bind_ip 127.0.0.1 --port 27017 --quiet"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "cd frontend && npx expo export --platform web --output-dir dist && npx serve dist -p 5000"]
build = ["sh", "-c", "cd frontend && npx expo export --platform web --output-dir dist"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
